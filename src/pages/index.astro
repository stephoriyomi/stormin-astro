---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Challenges from '../components/sections/Challenges.astro';
import Services from '../components/sections/Services.astro';
import Process from '../components/sections/Process.jsx';
import About from '../components/sections/About.astro';
import FAQ from '../components/sections/FAQ.astro';
import Contact from '../components/sections/Contact.jsx';

const title = 'Data Engineering Consulting — US & EU | Storm Inc';
const description =
  'Storm Inc builds production data pipelines, warehouses, and analytics platforms on Snowflake, dbt, and Airflow — for startups and mid-market companies in the US and EU.';
---

<BaseLayout title={title} description={description} canonicalUrl="https://storminc.eu/">
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Storm Inc",
    "url": "https://storminc.eu",
    "email": "support@storminc.eu",
    "description": "Data engineering consultancy specialising in pipelines, warehouses, and analytics platforms for startups and mid-market companies in the US and EU.",
    "areaServed": [
      { "@type": "Country", "name": "United States" },
      { "@type": "Place", "name": "European Union" }
    ],
    "knowsAbout": [
      "Data Engineering", "ETL Pipelines", "Data Warehousing", "Data Lakes",
      "dbt", "Snowflake", "BigQuery", "Databricks", "Apache Airflow", "Kafka",
      "Data Governance", "Machine Learning Infrastructure"
    ],
    "serviceType": "Data Engineering Consulting",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "support@storminc.eu",
      "contactType": "sales",
      "availableLanguage": "English",
      "areaServed": ["US", "EU"]
    }
  }
  </script>

  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you price engagements?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We work on either fixed-fee or time-and-materials, depending on how well-defined the scope is. For discovery, audits, or migrations with a clear endpoint, we prefer fixed-fee — you know what you're paying and what you're getting before we start. For longer-running build work where the scope evolves, T&M with a weekly cap is usually fairer to both sides. We don't charge for the initial discovery call, and we'll tell you upfront if we're not the right fit."
        }
      },
      {
        "@type": "Question",
        "name": "How long does a typical engagement take?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most engagements run 8 to 14 weeks end-to-end — from kickoff through hand-off. Shorter audits and architecture reviews can wrap in 2–3 weeks. Larger platform migrations occasionally extend to 4–6 months, but we break those into phased deliveries rather than running one continuous engagement."
        }
      },
      {
        "@type": "Question",
        "name": "Do you work fully remotely?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. We work remotely across US Eastern and EU Central timezones, with overlap hours that work for both. For longer engagements we can travel for kickoff or critical milestones if it genuinely helps the work — but we don't require it, and most clients prefer the lower overhead of remote-first delivery."
        }
      },
      {
        "@type": "Question",
        "name": "What stack do you specialize in?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our core stack is Snowflake, BigQuery, and Databricks for warehousing; dbt for transformation and modeling; Airflow and Kafka for orchestration and streaming; and Looker, Hex, and Metabase on the analytics side. For ML and feature engineering we use Feast, MLflow, and the major cloud-native services (SageMaker, Vertex AI). We're cloud-agnostic across AWS, GCP, and Azure."
        }
      },
      {
        "@type": "Question",
        "name": "Can you work with our existing data team, or do you replace them?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We work alongside existing teams — we're not a staffing replacement. The best engagements are the ones where your team is in the room, learning the reasoning behind every architectural decision. Every engagement ends with paired ownership, runbooks, and a documented system your team can extend without us. If you don't have a data team yet, we'll usually recommend hiring at least one person before we leave so the work doesn't stall."
        }
      },
      {
        "@type": "Question",
        "name": "What size company do you typically work with?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We work with startups (typically post-Series A, with real revenue and real data) and mid-market companies up to a few thousand employees. Our best fit is when you have enough data to need real infrastructure but not enough internal headcount to build it from scratch. We're not the right choice for very early-stage startups or enterprises that need a 50-person delivery team."
        }
      }
    ]
  }
  </script>

  <Hero />
  <Challenges />
  <Services />
  <Process client:visible />
  <About />
  <FAQ />
  <Contact client:visible />
</BaseLayout>
