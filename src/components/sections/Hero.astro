---
import '../../styles/hero.css';
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-text">
      <h1 class="hero-title">
        Data infrastructure that survives <em>contact with reality.</em>
      </h1>

      <p class="hero-subtitle">
        We build the pipelines, warehouses, and analytics layers your team will
        actually trust — for startups and mid-size companies across the US and EU.
      </p>

      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary btn-arrow">
          Book a discovery call
        </a>
        <a href="#services" class="btn btn-ghost btn-arrow">
          See how we work
        </a>
      </div>

      <div class="hero-meta">
        <span>Available · 2 slots Q3</span>
        <span aria-hidden="true">·</span>
        <span>US ET / EU CET</span>
        <span aria-hidden="true">·</span>
        <span>Fixed-fee or T&amp;M</span>
      </div>
    </div>

    <div class="hero-artifact" aria-hidden="true">
      <div class="artifact-card">
        <div class="artifact-header">
          <div class="artifact-dots">
            <span></span><span></span><span></span>
          </div>
          <span class="artifact-filename">pipelines/customer_360.yml</span>
          <span class="artifact-badge"><span class="dot"></span> healthy</span>
        </div>
        <pre class="artifact-code"><code>source:       postgres.production
destination:  snowflake.analytics
schedule:     "*/15 * * * *"

steps:
  - extract:    cdc &rarr; kafka
  - transform:  dbt (124 models)
  - test:       schema &middot; freshness &middot; volume
  - publish:    metrics_layer.v2

sla:          p99 &lt; 90s   &middot;   uptime 99.97%</code></pre>
      </div>

      <div class="artifact-stats">
        <div class="stat">
          <div class="stat-num">12.4M</div>
          <div class="stat-label">rows / hour</div>
        </div>
        <div class="stat">
          <div class="stat-num">99.97<span class="stat-pct">%</span></div>
          <div class="stat-label">uptime · 90d</div>
        </div>
        <div class="stat">
          <div class="stat-num">1.2<span class="stat-pct">s</span></div>
          <div class="stat-label">p99 latency</div>
        </div>
      </div>
    </div>
  </div>

  <div class="container hero-stack">
    <span class="stack-label">Working primarily with</span>
    <div class="stack-list">
      <span>Snowflake</span>
      <span>dbt</span>
      <span>BigQuery</span>
      <span>Databricks</span>
      <span>Airflow</span>
      <span>Postgres</span>
      <span>Kafka</span>
      <span>Looker</span>
    </div>
  </div>
</section>

